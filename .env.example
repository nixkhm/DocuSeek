# -----------------------------------------------------------------------------
# LLM Provider
# -----------------------------------------------------------------------------
# "openai" or "anthropic"
LLM_PROVIDER=openai

# OpenAI:   gpt-4o-mini, gpt-4o
# Anthropic: claude-sonnet-4-20250514, claude-haiku-4-5-20251001
LLM_MODEL=gpt-4o-mini

# OpenAI API key — required
OPENAI_API_KEY=sk-...

# Anthropic API key — required if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# Embeddings
# -----------------------------------------------------------------------------
EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/docuseek

# Postgres credentials (used by docker-compose db service)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=docuseek

# Local dev (if running backend outside Docker, point to localhost):
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/docuseek

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# Local dev (if running backend outside Docker):
# REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Session & Rate Limits
# -----------------------------------------------------------------------------
SESSION_TTL_DAYS=7
MAX_DOCS_PER_SESSION=5
MAX_PAGES_PER_DOC=50
MAX_FILE_SIZE_MB=20
RATE_LIMIT_QUERIES_PER_HOUR=20
RATE_LIMIT_UPLOADS_PER_HOUR=10

# -----------------------------------------------------------------------------
# Seed Data
# -----------------------------------------------------------------------------
SEED_DATA_ENABLED=true

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
